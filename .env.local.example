# Supabase — Dashboard → Settings → API / API Keys / Connect
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Any ONE publishable key env (docs use PUBLISHABLE_KEY; dashboard may show PUBLISHABLE_DEFAULT_KEY)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=   (legacy JWT anon)

# Same values, server-only — important for Vercel Edge middleware
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# SUPABASE_ANON_KEY=

# Migration only (never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=

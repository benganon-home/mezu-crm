# Supabase — Dashboard → Project Settings → API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# New dashboard key name (publishable default)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_YOUR_KEY

# Legacy name — same value as publishable key or anon JWT (optional if you use *_PUBLISHABLE_* only)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only copies — recommended on Vercel Edge for middleware (same values as above)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_YOUR_KEY
# or: SUPABASE_ANON_KEY=...

# Migration script only (never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=
